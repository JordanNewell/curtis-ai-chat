	"devDependencies": {
		"@types/node": "^20.11.0",
		"@typescript-eslint/eslint-plugin": "^6.19.0",
		"@typescript-eslint/parser": "^6.19.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.19.11",
		"eslint": "^8.56.0",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3"
	},
	"dependencies": {}
