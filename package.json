{
	"name": "curtis-ai-chat",
	"version": "1.0.1",
	"description": "Curtis AI Chat — your polyglot AI chat for Obsidian. 30+ providers, image attachments, memory, slash commands.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint src",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"ai",
		"chatgpt",
		"claude",
		"gemini",
		"ollama",
		"openai",
		"llm",
		"assistant",
		"rag",
		"agnostic",
		"multi-provider"
	],
	"author": "Jordan Newell",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@typescript-eslint/eslint-plugin": "^8.65.0",
		"@typescript-eslint/parser": "^8.65.0",
		"esbuild": "^0.19.11",
		"eslint": "^9.39.5",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"jiti": "^2.7.0",
		"obsidian": "^1.13.1",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3"
	}
}
